# Exness Trading Assistant Backend 环境配置示例
# 复制此文件为 .env 并修改相应配置

# API配置
API_V1_STR=/api
PROJECT_NAME=Exness Trading Assistant Backend

# 服务器配置
HOST=0.0.0.0
PORT=8000

# JWT认证配置 (生产环境请修改为强密钥)
SECRET_KEY=your-secret-key-change-in-production-please-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MT5配置 (留空使用默认路径)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PATH=

# CORS配置 (多个来源用逗号分隔)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://192.168.1.*

# 日志配置
LOG_LEVEL=INFO
